# health-ojimpo バックエンドAPIのベースURL
# Docker（同一ネットワーク）: http://backend:8000 / ホストから直接: http://localhost:8400
HEALTH_API_BASE_URL=http://backend:8000

# トランスポート: "http"（claude.ai / リモート用）または "stdio"（Claude Code / Desktop用、デフォルト）
TRANSPORT=http

# HTTPサーバーのポート（TRANSPORT=http のときのみ）
PORT=3000

# 任意: HTTPエンドポイントのBearer認証トークン（claude.aiカスタムコネクタは未対応のため通常は空）
MCP_AUTH_TOKEN=
